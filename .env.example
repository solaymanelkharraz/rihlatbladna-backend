# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Alwaysdata MySQL)
DB_HOST=mysql-username.alwaysdata.net
DB_USER=username_dbuser
DB_PASSWORD=your_secure_password
DB_NAME=username_dbname
DB_PORT=3306

# Authentication (JWT)
JWT_SECRET=your_jwt_super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
